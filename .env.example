PORT=3000

# Zona horaria del proceso Node y de las fechas/horas mostradas. El servidor
# de hosting corre en UTC por defecto; esto lo alinea con Mexico (sin DST
# desde 2022, siempre UTC-6).
TZ=America/Mexico_City

DB_HOST=localhost
DB_PORT=5432
DB_USER=crm_appgom
DB_PASSWORD=crm_appgom_dev
DB_NAME=crm_appgom

# SMTP (nativo de SiteGround por ahora; se puede migrar a Resend mas adelante
# sin tocar el resto del codigo, solo estas variables)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Correo(s) que reciben las alertas de administrador
ADMIN_EMAIL=sistemas@appgom.com

# Secreto para firmar las sesiones (JWT). Generar uno distinto por entorno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Nunca reutilizar el mismo valor entre local y produccion.
JWT_SECRET=

# Secreto separado para las sesiones del portal de clientes (nunca el mismo
# que JWT_SECRET, para que un token de un lado no sirva del otro).
PORTAL_JWT_SECRET=

# URL base publica del frontend, para armar enlaces en correos del portal
# (reset de password, aviso de acceso habilitado).
PORTAL_URL=https://crm.appgom.com
